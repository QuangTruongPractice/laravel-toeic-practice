# Laravel Production Configuration Template
# Copy this to .env on your production server and adjust values

# Application Settings
APP_NAME="TOEIC Practice Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
ASSET_URL=https://your-domain.com

# Database Configuration
# For production, use a managed database or secure database server
DB_CONNECTION=mysql
DB_HOST=your-db-host.com
DB_PORT=3306
DB_DATABASE=toeic_production
DB_USERNAME=toeic_user
DB_PASSWORD=your-secure-password-here

# Cache Configuration
# Use Redis for better performance in production
CACHE_DRIVER=redis
CACHE_PREFIX=toeic_cache_

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Queue Configuration
# Use Redis queue for background jobs
QUEUE_CONNECTION=redis
QUEUE_PREFIX=toeic_queue_

# Redis Configuration
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Mail Configuration
# Configure your email service (SendGrid, AWS SES, etc.)
MAIL_MAILER=sendgrid
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="TOEIC Practice Platform"
SENDGRID_API_KEY=your-sendgrid-api-key

# AWS Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-s3-bucket-name
AWS_URL=https://your-s3-bucket-name.s3.amazonaws.com

# File Storage Configuration
# Use 's3' for cloud storage, 'local' for local disk
FILESYSTEM_DISK=s3
FILESYSTEM_VISIBILITY=public

# Scout Configuration (for search functionality)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-key

# Sentry Configuration (for error tracking)
SENTRY_LARAVEL_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ENVIRONMENT=production

# Security Headers
TRUSTED_PROXIES=*
TRUSTED_HOSTS=your-domain.com,www.your-domain.com

# API Keys & Secrets (if applicable)
# OPENAI_API_KEY=sk-...

# Timezone
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Task Scheduling
# The scheduler should be run on the server via crontab
# Add this to your production server's crontab:
# * * * * * cd /path/to/laravel && php artisan schedule:run >> /dev/null 2>&1

# Queue Workers
# Run this in Supervisor to handle background jobs:
# php artisan queue:work redis --sleep=3 --tries=3
